# TradeFlow AgentOS uses synthetic/demo data only in Sprint 1.
# Do not add real API keys, production credentials, real customer data, or private business details.

TRADEFLOW_ENV=local
TRADEFLOW_USE_SYNTHETIC_DATA=true
TRADEFLOW_DRAFT_ONLY=true

# Sprint 007 planner provider selection.
# Keep deterministic as the default for tests and CI.
TRADEFLOW_PLANNER_PROVIDER=deterministic
TRADEFLOW_LLM_PROVIDER=openai
TRADEFLOW_LLM_MODEL=
TRADEFLOW_LLM_API_KEY=
TRADEFLOW_LLM_BASE_URL=
TRADEFLOW_LLM_TIMEOUT_SECONDS=30
