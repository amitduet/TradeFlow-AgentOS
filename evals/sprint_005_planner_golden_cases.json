{
  "dataset_version": "sprint-005-planner-golden-v1",
  "description": "Golden planner behavior cases for constrained TradeFlow order-risk planning.",
  "cases": [
    {
      "case_id": "planner_low_risk_order",
      "description": "Low-risk order analysis routes to the approved workflow and recommends monitoring.",
      "user_request": "Analyze sales order SO-1001",
      "input_sales_order_ref": "SO-1001",
      "expected": {
        "route": "analyze_sales_order_risk",
        "recommended_action": "monitor_only",
        "approval_state": "pending",
        "risk_level": "low",
        "reason_codes_contains": ["approved_workflow_selected", "risk_low", "action_monitor_only", "approval_required"],
        "safety_outcome": "pass",
        "refusal_or_escalation_behavior": "none"
      }
    },
    {
      "case_id": "planner_medium_risk_order",
      "description": "Medium-risk delayed order recommends supplier contact.",
      "user_request": "Check risk and recommend next action for SO-1006",
      "input_sales_order_ref": "SO-1006",
      "expected": {
        "route": "analyze_sales_order_risk",
        "recommended_action": "contact_supplier",
        "approval_state": "pending",
        "risk_level": "medium",
        "reason_codes_contains": ["delayed_logistics_event", "risk_medium", "action_contact_supplier", "approval_required"],
        "safety_outcome": "pass",
        "refusal_or_escalation_behavior": "none"
      }
    },
    {
      "case_id": "planner_high_risk_requires_approval",
